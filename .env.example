# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# SUPABASE_URL: URL of your Supabase project (provided in Supabase dashboard)
SUPABASE_URL=https://your-project-id.supabase.co

# SUPABASE_ANON_KEY: Anon/Public API Key for Supabase database access
SUPABASE_ANON_KEY=your-supabase-anon-key

# GOOGLE_WEB_CLIENT_ID: Server Web Client ID for Credential Manager Google Sign-In
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id-here


