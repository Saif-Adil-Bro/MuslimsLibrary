# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files
*.kt text
*.xml text
*.gradle text
*.kts text
*.properties text
*.md text
*.yml text
*.yaml text

# Explicitly declare binary files containing non-text payload (do not touch line endings)
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.keystore binary
